# ============================================
# Healthcare Prescription Analysis System
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# Google Gemini AI API (Required)
# ============================================
# Used for:
# - Prescription text and image analysis
# - X-ray analysis and comparison generation
# - Chat-based medical Q&A
# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Google Custom Search API (Optional)
# ============================================
# Used for pharmacy price lookup and medicine search
# Get your API key from: https://console.developers.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# Get your CSE ID from: https://cse.google.com/cse/
GOOGLE_CSE_ID=your_google_cse_id_here

# ============================================
# Session Security
# ============================================
# Secret key for session middleware encryption
# Change this to a secure random string in production
SESSION_SECRET_KEY=your_secure_random_session_key_here

# ============================================
# Backend Server Configuration
# ============================================
# Server host and port (optional - set if needed)
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# ============================================
# Frontend Configuration
# ============================================
# Frontend development server URL (optional)
# Vite will typically run on port 5173
# VITE_API_URL=http://localhost:8000
