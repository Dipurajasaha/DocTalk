# =============================================================================
# DocTalk Environment Configuration (Example)
# =============================================================================

# --- S3 bucket for storing uploaded files (PDFs, images, etc.) ---
bucket_name="your-bucket-name"
Access_key_ID="your-access-key-id"
Secret_access_key="your-secret-access-key"
Endpoint_url="https://[YOUR-PROJECT-REF].storage.supabase.co/storage/v1/s3"

# --- Supabase Database (PostgreSQL via Prisma) ---
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=3"
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
SHADOW_DATABASE_URL=

# --- Supabase Platform ---
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# --- Auth ---
JWT_SECRET_KEY="replace-this-with-a-secure-random-string-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="60"

# --- Admin Onboarding ---
ADMIN_ID="admin01"
ADMIN_NAME="Platform_Owner"
ADMIN_PASSWORD="Admin_2026"

# --- Mail configuration for sending email notifications ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="noreply@doctalk.app"
SMTP_FROM_NAME="DocTalk"

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID="rzp_test_YOUR_KEY"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_CURRENCY="INR"

# --- News API configuration for fetching news ---
NEWS_API_KEY="your-news-api-key"
NEWS_API_URL="https://newsdata.io/api/1/latest?q=health&language=en"

# --- Encryption & Security ---
ENCRYPTION_MASTER_KEY="your-encryption-master-key-base64"
PRESCRIPTION_SIGNING_PRIVATE_KEY="your-prescription-signing-private-key-base64"

# =============================================================================
# AI — Provider-Agnostic Configuration
# =============================================================================

# --- OpenAI-compatible LLM (text models) ---
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"
OPENAI_BASE_URL="https://api.openai.com/v1"

# --- Gemini (embeddings + vision) ---
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash-lite"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
GEMINI_EMBED_MODEL="gemini-embedding-001"

# --- Vision endpoint: gemini or imagga ---
VISION_ENDPOINT="gemini"

# --- Image analysis fallback (Imagga) ---
IMGAGA_API_KEY=""
IMGAGA_API_URL="https://api.imagga.com/v2"

# --- RAG / Tuning ---
AI_REQUEST_TIMEOUT_SECONDS="45"
XRAY_ANALYSIS_TIMEOUT_SECONDS="300"
RAG_EMBEDDING_TIMEOUT_SECONDS="120"
RAG_EMBEDDING_DIMENSION="768"
RAG_EMBEDDING_CACHE_SIZE="128"
RAG_MAX_MEMORY_AGE_DAYS="365"

# --- Local storage ---
DATA_ROOT=""
