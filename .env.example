# Root .env for DocTalk (sensitive values) — Keep this file out of version control
# Fill these values before running Docker or the application.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_EMBED_MODEL=nomic-embed-text
GOOGLE_CSE_ID=your_google_cse_id_here
SESSION_SECRET_KEY=your_secure_random_session_key_here
JWT_SECRET_KEY=change_me_to_a_secure_random_jwt_secret_32_plus
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=doctalk

# pgAdmin credentials (optional)
PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin

# Prisma / application DB connection strings
# When running services from your host machine, use localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doctalk
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/doctalk
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doctalk_shadow
