APP_NAME=DocTalk Backend
APP_VERSION=1.0.0
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change_me_to_a_secure_random_jwt_secret_32_plus
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_EMBED_MODEL=nomic-embed-text

POSTGRES_USER=doctalk
POSTGRES_PASSWORD=doctalk
POSTGRES_DB=doctalk
POSTGRES_PORT=5432

DATABASE_URL=postgresql://doctalk:doctalk@localhost:5432/doctalk?schema=public
DIRECT_URL=postgresql://doctalk:doctalk@localhost:5432/doctalk?schema=public
SHADOW_DATABASE_URL=postgresql://doctalk:doctalk@localhost:5432/doctalk_shadow?schema=public

PGADMIN_DEFAULT_EMAIL=admin@local
PGADMIN_DEFAULT_PASSWORD=admin

DATA_ROOT=./data
